{"version":"NotebookV1","origId":1083584440950840,"name":"12-2 AQE","language":"python","commands":[{"version":"CommandV1","origId":1083584440950841,"guid":"e21ef03e-bd9c-4a38-9ba7-18399c68f2cf","subtype":"command","commandType":"auto","position":1.0,"command":"\n%md\n# Adaptive Query Execution Demo\n\nAdaptive Query Execution (AQE) is query re-optimization that occurs during query execution based on runtime statistics. AQE in Spark 3.0 includes 3 main features:\n* Dynamically coalescing shuffle partitions\n* Dynamically switching join strategies\n* Dynamically optimizing skew joins","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"1cfe2ca2-a23d-4ad9-838a-899e71d48135"},{"version":"CommandV1","origId":1083584440950842,"guid":"0b8494d5-a6ca-4106-878c-bb91808481fa","subtype":"command","commandType":"auto","position":2.0,"command":"%md\n## Enable AQE","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"26468b24-ffcf-456c-bbcc-83e3c412e37f"},{"version":"CommandV1","origId":1083584440950843,"guid":"1517b453-9b9b-4538-81a7-71ff2bc1ab3c","subtype":"command","commandType":"auto","position":3.0,"command":"%sql\nset spark.sql.adaptive.enabled = true;","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"341","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"c30844ff-b2f1-4d5e-a684-35f8992bb716"},{"version":"CommandV1","origId":1083584440950844,"guid":"73dca618-1f1c-4c3b-8b7d-0ef6d6185d87","subtype":"command","commandType":"auto","position":4.0,"command":"%sql\n-- For demo purpose only.\n-- Not necessary in real-life usage.\n\nset spark.sql.adaptive.coalescePartitions.minPartitionNum = 1;","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"516","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"2789f75f-238a-486e-8f99-e3f1534f9bb0"},{"version":"CommandV1","origId":1083584440950845,"guid":"650ee15d-8533-43ea-9ff2-ca5642810b0e","subtype":"command","commandType":"auto","position":5.0,"command":"%md\n## Create Tables","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"d75e6ac1-c790-4223-a954-065e29c75ccc"},{"version":"CommandV1","origId":1083584440950846,"guid":"823da3fd-e0cc-4b8d-938e-f76570d8854f","subtype":"command","commandType":"auto","position":6.0,"command":"dbutils.fs.rm(\"dbfs:/user/hive/warehouse/aqe_demo_db\", True)","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"9c236043-8a92-47ac-9222-16a23d51fd90"},{"version":"CommandV1","origId":1083584440950847,"guid":"d73d3962-387e-4092-9602-060e101f8fe8","subtype":"command","commandType":"auto","position":7.0,"command":"%sql\nCREATE DATABASE IF NOT EXISTS aqe_demo_db;\nUSE aqe_demo_db;\n\nDROP TABLE IF EXISTS items;\nDROP TABLE IF EXISTS sales;\n\n-- Create \"items\" table.\n\nCREATE TABLE items\nUSING parquet\nAS\nSELECT id AS i_item_id,\nCAST(rand() * 1000 AS INT) AS i_price\nFROM RANGE(30000000);\n\n-- Create \"sales\" table with skew.\n-- Item with id 100 is in 80% of all sales.\n\nCREATE TABLE sales\nUSING parquet\nAS\nSELECT CASE WHEN rand() < 0.8 THEN 100 ELSE CAST(rand() * 30000000 AS INT) END AS s_item_id,\nCAST(rand() * 100 AS INT) AS s_quantity,\nDATE_ADD(current_date(), - CAST(rand() * 360 AS INT)) AS s_date\nFROM RANGE(1000000000);","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"7e86fbd4-2f79-4770-b96e-68095e0d84f6"},{"version":"CommandV1","origId":1083584440950848,"guid":"157e5234-9fe2-4038-92c7-dfd69d8d16b2","subtype":"command","commandType":"auto","position":8.0,"command":"%md\n## Dynamically Coalesce Shuffle Partitions","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"03c6c2f7-1100-4bf3-aa9c-0c71a5cefbf9"},{"version":"CommandV1","origId":1083584440950849,"guid":"f7893a98-849e-4e05-a489-daf200bc8d83","subtype":"command","commandType":"auto","position":9.0,"command":"%sql\n-- Get the sums of sales quantity grouped by sales date.\n-- The grouped result is very small.\n\nSELECT s_date, sum(s_quantity) AS q\nFROM sales\nGROUP BY s_date\nORDER BY q DESC;","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"6ac80d5d-2123-4754-8611-e27ec42e88d1"},{"version":"CommandV1","origId":1083584440950850,"guid":"cb076d88-3b80-45f5-8e09-d8e828db4a3f","subtype":"command","commandType":"auto","position":10.0,"command":"%md\n* The partition sizes after aggregation are very small: 13KB on average, 431KB in total (see the highlighted box **shuffle bytes written**).\n* AQE combines these small partitions into one new partition (see the highlighted box **CustomShuffleReader**).\n\n![screenshot_coalesce](https://docs.databricks.com/_static/images/spark/aqe/coalesce_partitions.png)","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"b6bc8f3f-b2c9-4bc7-80a1-cd013041cdf1"},{"version":"CommandV1","origId":1083584440950851,"guid":"d2ce759d-efce-4c53-9144-dd3585ee1dbf","subtype":"command","commandType":"auto","position":11.0,"command":"%md\n## Dynamically Switch Join Strategies","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"449c0d65-ddbb-4dc0-9747-ee936c3b1886"},{"version":"CommandV1","origId":1083584440950852,"guid":"8017cb91-d6dd-431e-86bb-53df6ee8735c","subtype":"command","commandType":"auto","position":12.0,"command":"%sql\n-- Get total sales amount grouped by sales date for items with a price lower than 10.\n-- The selectivity of the filter by price is not known in static planning, so the initial plan opts for sort merge join.\n-- But in fact, the \"items\" table after filtering is very small, so the query can do a broadcast hash join instead.\n\n-- Static explain shows the initial plan with sort merge join.\n\nEXPLAIN\nSELECT s_date, sum(s_quantity * i_price) AS total_sales\nFROM sales\nJOIN items ON s_item_id = i_item_id\nWHERE i_price < 10\nGROUP BY s_date\nORDER BY total_sales DESC;","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"5eab216e-6a2e-4e4a-a26c-45c0db3873b2"},{"version":"CommandV1","origId":1083584440950853,"guid":"d8c26228-cac2-46aa-bc79-e4fa7431065e","subtype":"command","commandType":"auto","position":13.0,"command":"%sql\n-- The runtime join strategy is changed to broadcast hash join.\n\nSELECT s_date, sum(s_quantity * i_price) AS total_sales\nFROM sales\nJOIN items ON s_item_id = i_item_id\nWHERE i_price < 10\nGROUP BY s_date\nORDER BY total_sales DESC;","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"a5753229-9c9a-4023-bb0a-dd2251a698c8"},{"version":"CommandV1","origId":1083584440950854,"guid":"34c846e9-d52f-4e32-8fe0-ed039207ead6","subtype":"command","commandType":"auto","position":14.0,"command":"%md\n* The data size of the \"items\" table after filtering is very small 6.9 MB (see the highlighted box **data size**).\n*  AQE changes the sort merge join to broadcast hash join at runtime (see the highlighted box **BroadcastHashJoin**).\n\n![screenshot_strategy](https://docs.databricks.com/_static/images/spark/aqe/join_strategy.png)","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"03b8070a-6aef-4467-ac47-018f95e3fba2"},{"version":"CommandV1","origId":1083584440950855,"guid":"d62fbbe9-824d-4af3-bbb5-8b7d7cdee3d3","subtype":"command","commandType":"auto","position":15.0,"command":"%md\n\n## Dynamically Optimize Skew Join","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"d18a06be-1167-4184-8ad8-9316eb3bbefe"},{"version":"CommandV1","origId":1083584440950856,"guid":"c96daaf2-1a7a-49d1-9d6e-1cc00317e449","subtype":"command","commandType":"auto","position":16.0,"command":"%sql\n-- Get the total sales amount grouped by sales date.\n-- The partition in the \"sales\" table containing value \"100\" as \"s_item_id\" is much larger than other partitions.\n-- AQE splits the skewed partition into smaller partitions before joining the \"sales\" table with the \"items\" table.\n\nSELECT s_date, sum(s_quantity * i_price) AS total_sales\nFROM sales\nJOIN items ON i_item_id = s_item_id\nGROUP BY s_date\nORDER BY total_sales DESC;","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"aad74a89-8241-483a-99df-6e448a245264"},{"version":"CommandV1","origId":1083584440950857,"guid":"33009c88-b057-49a6-aa37-47f7be9ac447","subtype":"command","commandType":"auto","position":17.0,"command":"%md\n* There is a skewed partition from the \"sales\" table (see the highlighted box **number of skewed partitions**).\n* AQE splits the skewed partition into smaller partitions (see the highlighted box **number of skewed partition splits**).\n* The sort merge join operator is marked with a skew join flag (see the highlighted box **SortMergeJoin(isSkew=true)**).\n\n![screenshot_skew](https://docs.databricks.com/_static/images/spark/aqe/skew_join.png)\n","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"701764d5-fee7-41d7-80ec-e7cfa556abe3"}],"dashboards":[],"guid":"9cae77a1-86d5-407c-a002-624f37be1fef","globalVars":{},"iPythonMetadata":null,"inputWidgets":{},"notebookMetadata":{"pythonIndentUnit":2}}