{"version":"NotebookV1","origId":1083584440950869,"name":"12-3 Pandas UDFs","language":"python","commands":[{"version":"CommandV1","origId":1083584440950870,"guid":"1da3562f-1d6e-4564-8bca-7b86d852c9a1","subtype":"command","commandType":"auto","position":1.0,"command":"\n%md\n# Pandas UDFs","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"c33a5e1b-cc08-4366-bec8-968277f270d7"},{"version":"CommandV1","origId":1083584440950871,"guid":"8dc5f447-ffb6-4afb-a263-31eac676f0f9","subtype":"command","commandType":"auto","position":2.0,"command":"import pandas as pd\nfrom pyspark.sql.functions import pandas_udf\n\n@pandas_udf(\"long\")\ndef pandas_plus_one(v: pd.Series) -> pd.Series:\n  return v + 1\n\ndf = spark.range(3)\ndf.withColumn(\"plus_one\", pandas_plus_one(\"id\")).show()","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"dc571a26-4a81-4eb8-9428-8b2ff0c0bbbf"},{"version":"CommandV1","origId":1083584440950872,"guid":"fdd07055-cb9b-4625-adfd-7e18353d4e09","subtype":"command","commandType":"auto","position":3.0,"command":"from typing import Iterator      \n\n@pandas_udf(\"long\")\ndef pandas_plus_one(iterator: Iterator[pd.Series]) -> Iterator[pd.Series]:\n  return map(lambda s: s + 1, iterator)\n\ndf.withColumn(\"plus_one\", pandas_plus_one(\"id\")).show()","commandVersion":3,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"309d5d36-26fc-4173-899c-716c09bad710"},{"version":"CommandV1","origId":1083584440950873,"guid":"5a9eba2b-1686-4135-8f2c-a46570f7083e","subtype":"command","commandType":"auto","position":4.0,"command":"def pandas_filter(iterator: Iterator[pd.DataFrame]) -> Iterator[pd.DataFrame]:\n  for pdf in iterator:\n    yield pdf[pdf.id == 1]\n\ndf.mapInPandas(pandas_filter, schema=df.schema).show()","commandVersion":1,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"68ddf769-3240-4d23-9197-07728b7dcbd1"},{"version":"CommandV1","origId":1083584440950874,"guid":"05d10f16-3867-4bf7-bc2c-821e8e129962","subtype":"command","commandType":"auto","position":5.0,"command":"df1 = spark.createDataFrame([(1201, 1, 1.0), (1201, 2, 2.0), (1202, 1, 3.0), (1202, 2, 4.0)], (\"time\", \"id\", \"v1\"))\ndf2 = spark.createDataFrame([(1201, 1, \"x\"), (1201, 2, \"y\")], (\"time\", \"id\", \"v2\"))\n\ndef asof_join(left: pd.DataFrame, right: pd.DataFrame) -> pd.DataFrame:\n  return pd.merge_asof(left, right, on=\"time\", by=\"id\")\n\ndf1.groupby(\"id\").cogroup(\n    df2.groupby(\"id\")\n).applyInPandas(asof_join, \"time int, id int, v1 double, v2 string\").show()\n","commandVersion":6,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"f2a0609e-e7d1-45d5-a271-4b2856989af7"}],"dashboards":[],"guid":"a847f79a-2740-4f71-9454-c6632909969b","globalVars":{},"iPythonMetadata":null,"inputWidgets":{},"notebookMetadata":{"pythonIndentUnit":2}}