,"command":"@pandas_udf(\"double\")\ndef vectorized_plus_one(v):\n    return v + 1\n\n%timeit -n1 -r1 df.withColumn(\"v\", vectorized_plus_one(df.v)).agg(count(col(\"v\"))).show()","commandVersion":7,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"13e9c54a-0868-4ea2-8911-1d8e02c3e96e"},{"version":"CommandV1","origId":1083584440950669,"guid":"feab4733-bcc6-4906-a32c-af8c9e35e556","subtype":"command","commandType":"auto","position":19.0,"command":"%md\nAlright! Still not as great as the Scala UDF, but at least it's better than the regular Python UDF!\n\nHere's some alternate syntax for the Pandas UDF.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"c059db2f-4c64-4221-b62b-5c5a9127f68a"},{"version":"CommandV1","origId":1083584440950670,"guid":"92990487-288a-4db8-8982-d0c76896d525","subtype":"command","commandType":"auto","position":20.0,"command":"from pyspark.sql.functions import pandas_udf\n\ndef vectorized_plus_one(v):\n    return v + 1\n\nvectorized_plus_one_udf = pandas_udf(vectorized_plus_one, \"double\")\n\n%timeit -n1 -r1 df.withColumn(\"v\", vectorized_plus_one_udf(df.v)).agg(count(col(\"v\"))).show()","commandVersion":5,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"131c23b2-8af8-462e-a3f9-0a67d06d7e8a"},{"version":"CommandV1","origId":1083584440950671,"guid":"b3a50d80-ed38-4a75-b8bb-fdbcebc0a54f","subtype":"command","commandType":"auto","position":21.0,"command":"%md\n### Built-in Method\n\nLet's compare the performance of the UDFs with using the built-in method.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"d0c9e277-7dca-4258-b8d1-3087096bcc9e"},{"version":"CommandV1","origId":1083584440950672,"guid":"5c35b3da-2366-41f4-9308-eacdb1e9b098","subtype":"command","commandType":"auto","position":22.0,"command":"from pyspark.sql.functions import lit\n\n%timeit -n1 -r1 df.withColumn(\"v\", df.v + lit(1)).agg(count(col(\"v\"))).show()","commandVersion":5,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"06375400-2aab-4b3b-928e-12927e2dbd6b"},{"version":"CommandV1","origId":1083584440950673,"guid":"a27aeaa4-a601-4b53-bf58-34df2e3a296c","subtype":"command","commandType":"auto","position":23.0,"command":"%md\n## Computing subtract mean\n\nUp above, we were working with Scalar return types. Now we can use grouped UDFs.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"d9be4dfe-10e8-416a-ba33-42a5b811832c"},{"version":"CommandV1","origId":1083584440950674,"guid":"2f273709-a6f1-4d3e-8610-27a42ff33c6c","subtype":"command","commandType":"auto","position":24.0,"command":"%md\n### PySpark UDF","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"51f3cf73-2b3d-4662-8cfc-9bbe164b8c20"},{"version":"CommandV1","origId":1083584440950675,"guid":"f7703ff0-1a95-43ca-85ee-e309ec5f6d74","subtype":"command","commandType":"auto","position":25.0,"command":"from pyspark.sql import Row\nimport pandas as pd\n\n@udf(ArrayType(df.schema))\ndef subtract_mean(rows):\n  vs = pd.Series([r.v for r in rows])\n  vs = vs - vs.mean()\n  return [Row(id=rows[i][\"id\"], v=float(vs[i])) for i in range(len(rows))]\n  \n%timeit -n1 -r1 (df.groupby(\"id\").agg(collect_list(struct(df[\"id\"], df[\"v\"])).alias(\"rows\")).withColumn(\"new_rows\", subtract_mean(col(\"rows\"))).withColumn(\"new_row\", explode(col(\"new_rows\"))).withColumn(\"id\", col(\"new_row.id\")).withColumn(\"v\", col(\"new_row.v\")).agg(count(col(\"v\"))).show())","commandVersion":39,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"5446d7c0-dda4-434c-a580-0ba6ef59dc3f"},{"version":"CommandV1","origId":1083584440950676,"guid":"f52f0771-886c-4df9-8ef8-b6fc4a4f5ea0","subtype":"command","commandType":"auto","position":26.0,"command":"%md\n### Vectorized UDF","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"1662a4cc-3f4d-4cf2-98ca-1e2809f951a7"},{"version":"CommandV1","origId":1083584440950677,"guid":"75822fd2-d41c-460e-90c6-dc9317fec984","subtype":"command","commandType":"auto","position":27.0,"command":"def vectorized_subtract_mean(pdf: pd.Series) -> pd.Series:\n\treturn pdf.assign(v=pdf.v - pdf.v.mean())\n\n%timeit -n1 -r1 df.groupby(\"id\").applyInPandas(vectorized_subtract_mean, df.schema).agg(count(col(\"v\"))).show()","commandVersion":9,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"c7d9f7a0-589b-4e5b-84b4-1a08fcaf7a80"}],"dashboards":[],"guid":"abd55943-39e3-4df4-a255-7f84f7880f6b","globalVars":{},"iPythonMetadata":null,"inputWidgets":{},"notebookMetadata":{"pythonIndentUnit":2}}