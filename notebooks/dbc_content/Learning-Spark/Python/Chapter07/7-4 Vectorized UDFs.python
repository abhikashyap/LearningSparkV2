{"version":"NotebookV1","origId":1083584440950650,"name":"7-4 Vectorized UDFs","language":"python","commands":[{"version":"CommandV1","origId":1083584440950651,"guid":"e9bca789-1770-400b-8896-ccb92b7e33ea","subtype":"command","commandType":"auto","position":1.0,"command":"\n%md\n# Vectorized User Defined Functions\n\nLet's compare the performance of UDFs, Vectorized UDFs, and built-in methods.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"7e681c1a-52b5-43bd-ba9e-c682be7ced13"},{"version":"CommandV1","origId":1083584440950652,"guid":"7e9ee28a-9bf8-425e-842b-1cd2d91ec5ad","subtype":"command","commandType":"auto","position":2.0,"command":"%md\nStart by generating some dummy data.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"df6c890a-28d4-4e07-a616-c658bf619626"},{"version":"CommandV1","origId":1083584440950653,"guid":"ffd51a3d-0cc3-4b68-a575-efe1fa72b384","subtype":"command","commandType":"auto","position":3.0,"command":"from pyspark.sql.types import *\nfrom pyspark.sql.functions import col, count, rand, collect_list, explode, struct, count, pandas_udf\n\ndf = (spark\n      .range(0, 10 * 1000 * 1000)\n      .withColumn(\"id\", (col(\"id\") / 1000).cast(\"integer\"))\n      .withColumn(\"v\", rand()))\n\ndf.cache()\ndf.count()","commandVersion":6,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"281aa94a-e7a3-40f4-9851-99f30773219c"},{"version":"CommandV1","origId":1083584440950654,"guid":"21b5ae64-6993-4aa9-8042-963b1cc18b90","subtype":"command","commandType":"auto","position":4.0,"command":"%md\n## Incrementing a column by one\n\nLet's start off with a simple example of adding one to each value in our DataFrame.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"7b2f22de-80c5-47da-9ee6-579c81d17b69"},{"version":"CommandV1","origId":1083584440950655,"guid":"5a7554de-f3fd-4a09-9e7e-6376872cf55c","subtype":"command","commandType":"auto","position":5.0,"command":"%md\n### PySpark UDF","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"276ec728-8288-4245-b5b8-de3e353f6825"},{"version":"CommandV1","origId":1083584440950656,"guid":"6d193916-fc4e-4369-8c0d-882e0c267937","subtype":"command","commandType":"auto","position":6.0,"command":"@udf(\"double\")\ndef plus_one(v):\n    return v + 1\n\n%timeit -n1 -r1 df.withColumn(\"v\", plus_one(df.v)).agg(count(col(\"v\"))).show()","commandVersion":5,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"d7e643d0-8a3b-47f0-ac93-725e765b46c1"},{"version":"CommandV1","origId":1083584440950657,"guid":"fffe79f5-bbbc-49c5-95e7-24dd88fae7b7","subtype":"command","commandType":"auto","position":7.0,"command":"%md\nAlternate Syntax (can also use in the SQL namespace now)","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"79e54b03-9b5e-40aa-952c-ca0621f4d496"},{"version":"CommandV1","origId":1083584440950658,"guid":"9993973e-b680-40e3-a2fd-5f05f01b0b33","subtype":"command","commandType":"auto","position":8.0,"command":"from pyspark.sql.types import DoubleType\n\ndef plus_one(v):\n    return v + 1\n  \nspark.udf.register(\"plus_one_udf\", plus_one, DoubleType())\n\n%timeit -n1 -r1 df.selectExpr(\"id\", \"plus_one_udf(v) as v\").agg(count(col(\"v\"))).show()","commandVersion":3,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"3f288597-068b-4964-badc-ae38400384a2"},{"version":"CommandV1","origId":1083584440950659,"guid":"175faddf-4da4-4109-b619-ef9caec060fc","subtype":"command","commandType":"auto","position":9.0,"command":"%md\n### Scala UDF\n\nYikes! That took awhile to add 1 to each value. Let's see how long this takes with a Scala UDF.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"5843f332-fa33-49f0-8246-ca95a5a358bb"},{"version":"CommandV1","origId":1083584440950660,"guid":"7860cb49-d3c3-4d60-8319-bd5a06381cc8","subtype":"command","commandType":"auto","position":10.0,"command":"df.createOrReplaceTempView(\"df\")","commandVersion":1,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"107335cf-2041-47cd-919e-0b2958215bdb"},{"version":"CommandV1","origId":1083584440950661,"guid":"b03ae1ac-fba3-454a-a0e2-15280dc63b7a","subtype":"command","commandType":"auto","position":11.0,"command":"%scala\nimport org.apache.spark.sql.functions._\n\nval df = spark.table(\"df\")\n\ndef plusOne: (Double => Double) = { v => v+1 }\nval plus_one = udf(plusOne)","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"20ea85ac-1254-4f56-9eda-e69a99e01f33"},{"version":"CommandV1","origId":1083584440950662,"guid":"9999ad93-5d0c-4ed0-a386-20b73ed4cc07","subtype":"command","commandType":"auto","position":12.0,"command":"%scala\ndf.withColumn(\"v\", plus_one($\"v\"))\n  .agg(count(col(\"v\")))\n  .show()","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"d0920b9f-ed93-40d1-85d0-f7832cf30fd0"},{"version":"CommandV1","origId":1083584440950663,"guid":"7e8faf48-b926-462f-92de-cc93ed57a62a","subtype":"command","commandType":"auto","position":13.0,"command":"%md\nWow! That Scala UDF was a lot faster. However, as of Spark 2.3, there are Vectorized UDFs available in Python to help speed up the computation.\n\n* [Blog post](https://databricks.com/blog/2017/10/30/introducing-vectorized-udfs-for-pyspark.html)\n* [Documentation](https://spark.apache.org/docs/latest/sql-programming-guide.html#pyspark-usage-guide-for-pandas-with-apache-arrow)\n\n![Benchmark](https://databricks.com/wp-content/uploads/2017/10/image1-4.png)\n\nVectorized UDFs utilize Apache Arrow to speed up computation. Let's see how that helps improve our processing time.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"abe380c7-7bb7-48ad-a83a-df2034f2caab"},{"version":"CommandV1","origId":1083584440950664,"guid":"14456ede-eddc-4188-b89a-73f824e9ec01","subtype":"command","commandType":"auto","position":14.0,"command":"%md\n[Apache Arrow](https://arrow.apache.org/), is an in-memory columnar data format that is used in Spark to efficiently transfer data between JVM and Python processes. See more [here](https://spark.apache.org/docs/latest/sql-pyspark-pandas-with-arrow.html).\n\nLet's take a look at how long it takes to convert a Spark DataFrame to Pandas with and without Apache Arrow enabled.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"9802beae-2b48-43e1-b89a-8ed075e2a728"},{"version":"CommandV1","origId":1083584440950665,"guid":"85e408e2-1766-4cab-bd0b-de88df01ad04","subtype":"command","commandType":"auto","position":15.0,"command":"spark.conf.set(\"spark.sql.execution.arrow.enabled\", \"true\")\n\n%timeit -n1 -r1 df.toPandas()","commandVersion":1,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"8208b4cc-935d-42de-9010-7cba775a6c43"},{"version":"CommandV1","origId":1083584440950666,"guid":"ea1f3358-ee5f-4ccc-bd3f-fb30562fcf5a","subtype":"command","commandType":"auto","position":16.0,"command":"spark.conf.set(\"spark.sql.execution.arrow.enabled\", \"false\")\n\n%timeit -n1 -r1 df.toPandas()","commandVersion":1,"sta