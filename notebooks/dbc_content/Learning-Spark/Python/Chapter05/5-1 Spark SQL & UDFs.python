auto","position":51.0,"command":"%md\n### Pivoting\nGreat reference [SQL Pivot: Converting Rows to Columns](https://databricks.com/blog/2018/11/01/sql-pivot-converting-rows-to-columns.html)","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"18614995-8403-4c87-a563-ca7fe4f87fb2"},{"version":"CommandV1","origId":1083584440950992,"guid":"925b93ed-d777-46c1-98e4-07acddd86e72","subtype":"command","commandType":"auto","position":52.0,"command":"spark.sql(\"\"\"SELECT destination, CAST(SUBSTRING(date, 0, 2) AS int) AS month, delay FROM departureDelays WHERE origin = 'SEA'\"\"\").show(10)","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"512a1f1e-eb59-4a1b-bb70-abcc794466fe"},{"version":"CommandV1","origId":1083584440950993,"guid":"37e9990a-99e7-4c96-8e2f-2ef47b3e9379","subtype":"command","commandType":"auto","position":53.0,"command":"spark.sql(\"\"\"\nSELECT * FROM (\nSELECT destination, CAST(SUBSTRING(date, 0, 2) AS int) AS month, delay \n  FROM departureDelays WHERE origin = 'SEA' \n) \nPIVOT (\n  CAST(AVG(delay) AS DECIMAL(4, 2)) as AvgDelay, MAX(delay) as MaxDelay\n  FOR month IN (1 JAN, 2 FEB, 3 MAR)\n)\nORDER BY destination\n\"\"\").show()","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"ad0b27da-f6b2-4625-985c-c0119ed85610"},{"version":"CommandV1","origId":1083584440950994,"guid":"e9cb423e-d13b-4bd5-b7b0-c5758efa4496","subtype":"command","commandType":"auto","position":54.0,"command":"spark.sql(\"\"\"\nSELECT * FROM (\nSELECT destination, CAST(SUBSTRING(date, 0, 2) AS int) AS month, delay \n  FROM departureDelays WHERE origin = 'SEA' \n) \nPIVOT (\n  CAST(AVG(delay) AS DECIMAL(4, 2)) as AvgDelay, MAX(delay) as MaxDelay\n  FOR month IN (1 JAN, 2 FEB)\n)\nORDER BY destination\n\"\"\").show()","commandVersion":