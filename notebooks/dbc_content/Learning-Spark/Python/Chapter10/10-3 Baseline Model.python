{"version":"NotebookV1","origId":1083584440950759,"name":"10-3 Baseline Model","language":"python","commands":[{"version":"CommandV1","origId":1083584440950760,"guid":"94f6449a-bdc6-4dd8-80ff-f46b4a50717c","subtype":"command","commandType":"auto","position":1.0,"command":"\n%md\n# Baseline Model\n\nLet's compute the average `price` on the training dataset, and use that as our prediction column for our test dataset, then evaluate the result.","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"24d7fba7-e7df-4ba0-b906-aa4a437e7e53"},{"version":"CommandV1","origId":1083584440950761,"guid":"5bd7b661-046f-41cf-9051-80679fb7526d","subtype":"command","commandType":"auto","position":2.0,"command":"from pyspark.sql.functions import avg, lit\n\nfilePath = \"/databricks-datasets/learning-spark-v2/sf-airbnb/sf-airbnb-clean.parquet\"\nairbnbDF = spark.read.parquet(filePath)\ntrainDF, testDF = airbnbDF.randomSplit([.8, .2], seed=42)\n\navgPrice = float(trainDF.select(avg(\"price\")).first()[0])\npredDF = testDF.withColumn(\"avgPrediction\", lit(avgPrice))","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"6b3c239a-04c0-4613-b75c-05eb82f8050a"},{"version":"CommandV1","origId":1083584440950762,"guid":"281f7a60-b1a7-4602-813e-b7003ea9157d","subtype":"command","commandType":"auto","position":3.0,"command":"from pyspark.ml.evaluation import RegressionEvaluator\n\nregressionMeanEvaluator = RegressionEvaluator(predictionCol=\"avgPrediction\", labelCol=\"price\", metricName=\"rmse\")\n\nprint(f\"The RMSE for predicting the average price is: {regressionMeanEvaluator.evaluate(predDF):.2f}\")\n","commandVersion":0,"state":"error","results":null,"errorSummary":null,"errorTraceType":null,"error":null,"workflows":[],"startTime":0,"submitTime":0,"finishTime":0,"collapsed":false,"bindings":{},"inputWidgets":{},"displayType":"table","width":"auto","height":"auto","xColumns":null,"yColumns":null,"pivotColumns":null,"pivotAggregation":null,"useConsistentColors":false,"customPlotOptions":{},"commentThread":[],"commentsVisible":false,"parentHierarchy":[],"diffInserts":[],"diffDeletes":[],"globalVars":{},"latestUser":"a user","latestUserId":null,"commandTitle":"","showCommandTitle":false,"hideCommandCode":false,"hideCommandResult":false,"isLockedInExamMode":false,"iPythonMetadata":null,"streamStates":{},"datasetPreviewNameToCmdIdMap":{},"tableResultSubCmdIds":[],"tableResultIndex":null,"nuid":"882b0830-2609-4b39-a5fc-42c7e79148aa"}],"dashboards":[],"guid":"459785a3-db7c-4ed6-87ca-e66a6b6ececb","globalVars":{},"iPythonMetadata":null,"inputWidgets":{},"notebookMetadata":{"pythonIndentUnit":2}}